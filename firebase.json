{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/sign-cloudinary",
        "function": { "functionId": "signCloudinary" }
      },
      {
        "source": "/api/delete-cloudinary",
        "function": { "functionId": "deleteCloudinary" }
      },
      {
        "source": "/api/send-email",
        "function": { "functionId": "sendEmail" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
